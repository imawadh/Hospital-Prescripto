# Copy this file to ".env" and fill in real values:  cp .env.example .env

# ---- Server ----
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed browser origins (NO trailing slash).
# Leave EMPTY for local development (all origins are allowed).
# In production, set it to your deployed frontend URLs, e.g.:
#   CORS_ORIGINS=https://awadh-hospital-admin-app.vercel.app,https://awadh-doctor-app.vercel.app,https://awadh-patient-app.vercel.app
CORS_ORIGINS=

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net
MONGODB_DB=prescripto

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---- Auth ----
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Admin account ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use_a_strong_password

# ---- Display currency ----
CURRENCY=INR

# ---- Seed script (npm run seed) ----
# Public base URL of THIS server — used to build seeded doctor image URLs.
# Leave unset locally (defaults to http://localhost:PORT).
# In production set it to the deployed API URL, e.g.:
#   BACKEND_URL=https://hospital-prescripto.onrender.com
BACKEND_URL=
