# Copy this file to ".env":  cp .env.example .env
#
# Base URL of the Prescripto API server.
#   Local development : http://localhost:4000  (run the server locally)
#   Production        : your deployed API URL, e.g.
#                        https://hospital-prescripto.onrender.com
#
# On Vercel, set VITE_BACKEND_URL in Project Settings > Environment Variables
# instead of committing it here.
VITE_BACKEND_URL=http://localhost:4000
